# Copy to /etc/systemd/system/pretzel-server.service, adjust User and paths, then:
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now pretzel-server
#
# Listens on :3001 (see index.js). Start before remote-ui; tv-relay is independent.

[Unit]
Description=Pretzel Pi speaker API (TTS, volume, weather on :3001)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/pretzel/pretzel-server
ExecStart=/usr/bin/node index.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production
# Optional: match repo root VERSION after deploy (see README).
# Environment=PRETZEL_STACK_VERSION=1.0.0

[Install]
WantedBy=multi-user.target
